# =============================================
# Game QA Testcase — 환경 변수 설정 템플릿
# 이 파일을 .env로 복사 후 실제 값을 채워주세요
# cp .env.example .env
# =============================================

# Google OAuth 클라이언트 시크릿 파일 경로
# Google Cloud Console > API 및 서비스 > 사용자 인증 정보에서 다운로드
GOOGLE_OAUTH_CLIENT_SECRET_PATH=./credentials/client_secret.json

# OAuth 토큰 저장 경로 (최초 인증 후 자동 생성)
GOOGLE_OAUTH_TOKEN_PATH=./credentials/oauth_token.json

# TC 마스터 스프레드시트 ID
# URL 예시: https://docs.google.com/spreadsheets/d/[여기가 ID]/edit
MASTER_SPREADSHEET_ID=your_spreadsheet_id_here

# Google Drive 폴더 ID
# URL 예시: https://drive.google.com/drive/folders/[여기가 ID]
TC_DRIVE_FOLDER_ID=your_tc_folder_id_here
SPEC_DRIVE_FOLDER_ID=your_spec_folder_id_here

# 이 레포를 클론한 절대 경로
# 예: C:/Users/YourName/Documents/Game_QA_Testcase
# 예: /home/username/Game_QA_Testcase
WORK_ROOT=C:/Users/YourName/Documents/Game_QA_Testcase

# Claude Code 사용자 디렉토리 (agents/skills/commands 설치 위치)
# 예: C:/Users/YourName/.claude  (Windows)
# 예: /home/username/.claude      (Linux/macOS)
CLAUDE_HOME=C:/Users/YourName/.claude

# Confluence (Atlassian) 사이트 — 기획서 페이지 읽기 소스
CONFLUENCE_SITE=https://YOUR_SITE.atlassian.net
CONFLUENCE_SITE_HOST=YOUR_SITE.atlassian.net

# Google Sheets Dashboard IDs (여러 대시보드 사용 시)
MASTER_DASHBOARD_ID=your_master_dashboard_id
INTEGRATION_TC_ID=your_integration_tc_id
GAME_QA_ID=your_game_qa_id

# =============================================
# Gemma4 — 백엔드 선택 (2가지 중 택 1)
# =============================================
# 옵션 A: 로컬 Ollama  — 무료, 네트워크 불필요, VRAM 필요 (~17GB)
# 옵션 B: Google AI Studio — 무료 티어, VRAM 불필요, 네트워크 필요
#
# GEMMA4_BACKEND=ollama  → 옵션 A (기본)
# GEMMA4_BACKEND=google  → 옵션 B
GEMMA4_BACKEND=ollama

# --- 옵션 A: 로컬 Ollama ---
# 먼저 Ollama 설치 후 모델 pull:
#   ollama pull gemma4:26b   # 권장 — MoE A4B (26B total, 4B active/token, 빠름)
# 다른 옵션:
#   gemma4:31b     # Dense, 느림 (배치 작업 비권장)
#   gemma4:latest  # E4B (8B 물리 / 4B 유효, 멀티모달 — 경량 분석용)
GEMMA4_MODEL=gemma4:26b
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_CHAT_URL=http://localhost:11434/api/chat
GEMMA4_TIMEOUT_MS=300000
GEMMA4_TIMEOUT_SEC=1800

# --- 옵션 B: Google AI Studio (클라우드) ---
# 1. API 키 발급 (무료): https://aistudio.google.com/app/apikey
# 2. GEMMA4_BACKEND=google 로 변경
# 3. GOOGLE_AI_API_KEY 에 발급받은 키 붙여넣기
#
# 무료 티어 rate limit (2025 기준, 변경될 수 있음):
#   gemma-4-31b-it: 분당 15 RPM / 일당 1500 RPD
#
# 사용 가능한 모델:
#   gemma-4-31b-it    # 31B dense IT, 최고 품질 (권장)
#   gemma-4-26b-a4b   # 26B MoE, 빠름
#   gemma-4-e4b       # E4B 경량
GOOGLE_AI_API_KEY=your_google_ai_studio_api_key_here
GOOGLE_AI_MODEL=gemma-4-31b-it
