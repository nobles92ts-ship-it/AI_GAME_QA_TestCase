# =============================================
# Game QA Testcase — 환경 변수 설정 템플릿
# 이 파일을 .env로 복사 후 실제 값을 채워주세요
# cp .env.example .env
# =============================================

# Google OAuth 클라이언트 시크릿 파일 경로
# Google Cloud Console > API 및 서비스 > 사용자 인증 정보에서 다운로드
GOOGLE_OAUTH_CLIENT_SECRET_PATH=./credentials/client_secret.json

# OAuth 토큰 저장 경로 (최초 인증 후 자동 생성)
GOOGLE_OAUTH_TOKEN_PATH=./credentials/oauth_token.json

# TC 마스터 스프레드시트 ID
# URL 예시: https://docs.google.com/spreadsheets/d/[여기가 ID]/edit
MASTER_SPREADSHEET_ID=your_spreadsheet_id_here

# Google Drive 폴더 ID
# URL 예시: https://drive.google.com/drive/folders/[여기가 ID]
TC_DRIVE_FOLDER_ID=your_tc_folder_id_here
SPEC_DRIVE_FOLDER_ID=your_spec_folder_id_here

# 이 레포를 클론한 절대 경로
# 예: C:/Users/YourName/Documents/Game_QA_Testcase
# 예: /home/username/Game_QA_Testcase
WORK_ROOT=C:/Users/YourName/Documents/Game_QA_Testcase
